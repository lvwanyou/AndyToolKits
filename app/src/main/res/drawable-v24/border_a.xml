<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:bottom="0dp"
        android:left="0dp"
        android:right="0dp"
        android:top="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" /> <!-- 内部透明 -->
            <stroke
                android:width="2dp"
                android:color="#FF0000" /> <!-- 边框颜色和宽度 -->
        </shape>
    </item>
</layer-list>
